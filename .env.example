# ─── Local development ────────────────────────────────────────────────────────
# Copy this file to .env for local dev:  cp .env.example .env

# API base URL — leave blank for local dev (same-origin, Express on same port)
VITE_API_BASE=

# Express server port
PORT=5000

# ─── Production notes ─────────────────────────────────────────────────────────
# When building for production (npm run build):
# - Do NOT set VITE_API_BASE — the deploy_website tool replaces __PORT_5000__
#   in the built JS bundle automatically with the proxy path.
# - PORT=5000 is used by the Express server (server/index.ts)
#
# If running frontend + backend on separate hosts:
# VITE_API_BASE=https://your-api.example.com
